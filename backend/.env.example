PORT=5000
MONGODB_URI=mongodb://localhost:27017/hr_management
JWT_SECRET=your_secret_key_here
NODE_ENV=development

# Admin Credentials (NEVER commit real values)
ADMIN_USERNAME=admin01
ADMIN_PASSWORD=admin123

# WhatsApp Support
WHATSAPP_SUPPORT_NUMBER=+201228195728

# Encryption Keys
FRONTEND_ENCRYPTION_KEY=careerak_secure_key_2024

# Session Security
SESSION_SECRET=your_session_secret_here

# Logging
LOG_LEVEL=info

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Performance
API_TIMEOUT=30000

# OAuth Configuration (Enhanced Auth)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Google Calendar Integration
# GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET are shared with OAuth above
GOOGLE_REDIRECT_URI=http://localhost:5000/integrations/google/callback
# Encryption key for storing Google tokens (32 chars, use OAUTH_ENCRYPTION_KEY if already set)
# GOOGLE_ENCRYPTION_KEY=generate_32_char_key_here
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here
LINKEDIN_REDIRECT_URI=http://localhost:3000/linkedin/callback
OAUTH_CALLBACK_URL=http://localhost:5000/auth

# OAuth Token Encryption (CRITICAL: Generate a strong 32-character key)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OAUTH_ENCRYPTION_KEY=GENERATE_A_STRONG_32_CHAR_KEY_HERE

# Email Service (for verification emails)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_email_password_here
EMAIL_FROM=noreply@careerak.com

# Google reCAPTCHA v3 (CAPTCHA for bot prevention)
RECAPTCHA_ENABLED=false
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here
RECAPTCHA_MIN_SCORE=0.5

# Pusher Configuration (Real-time updates)
PUSHER_APP_ID=your_pusher_app_id_here
PUSHER_KEY=your_pusher_key_here
PUSHER_SECRET=your_pusher_secret_here
PUSHER_CLUSTER=eu

# WebRTC Configuration (Video Interviews)
# TURN Server (Required for video calls behind firewalls)
# You can use a free service like:
# - Twilio TURN: https://www.twilio.com/stun-turn
# - Xirsys: https://xirsys.com/
# - Or host your own: https://github.com/coturn/coturn
TURN_SERVER_URL=turn:turn.careerak.com:3478
TURN_USERNAME=careerak
TURN_PASSWORD=secure_password_here

# Video Interview Settings
VIDEO_MAX_PARTICIPANTS=10
VIDEO_MAX_DURATION=180
VIDEO_RECORDING_ENABLED=true
VIDEO_RECORDING_EXPIRY_DAYS=90

# SMS Configuration (Optional - Twilio)
# SMS is disabled by default. Set SMS_ENABLED=true and configure Twilio to enable.
# Get credentials from: https://www.twilio.com/console
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
